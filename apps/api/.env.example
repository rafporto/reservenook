# Spring Boot server
SERVER_PORT=8080

# Database connection
DATABASE_URL=jdbc:postgresql://localhost:5432/reservenook
DATABASE_USERNAME=reservenook
DATABASE_PASSWORD=reservenook

# Local mail sandbox
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
PUBLIC_APP_BASE_URL=http://localhost:3000
OPERATIONS_ALERTS_ENABLED=false
OPERATIONS_ALERTS_RECIPIENT_EMAIL=
OPERATIONS_ALERTS_FROM_EMAIL=noreply@reservenook.local
OPERATIONS_ALERTS_COOLDOWN_MINUTES=30

# Future email and integration settings should be added here as the backend evolves.
