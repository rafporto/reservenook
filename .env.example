# Shared local infrastructure defaults
POSTGRES_DB=reservenook
POSTGRES_USER=reservenook
POSTGRES_PASSWORD=reservenook

# Local service ports
API_PORT=8080
WEB_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# Frontend public URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_DEFAULT_LOCALE=en
PUBLIC_APP_BASE_URL=http://localhost:3000

# Backend service wiring
DATABASE_URL=jdbc:postgresql://postgres:5432/reservenook
DATABASE_USERNAME=reservenook
DATABASE_PASSWORD=reservenook
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
OPERATIONS_ALERTS_ENABLED=false
OPERATIONS_ALERTS_RECIPIENT_EMAIL=
OPERATIONS_ALERTS_FROM_EMAIL=noreply@reservenook.local
OPERATIONS_ALERTS_COOLDOWN_MINUTES=30
